GEMINI_API_KEY=

# Chat model backend: "gemini" (default) or "groq". Embeddings always use
# Gemini regardless. To switch to Groq (e.g. llama-3.3-70b-versatile), set
# LLM_PROVIDER=groq and fill in GROQ_API_KEY below.
LLM_PROVIDER=gemini
LLM_MODEL=
GROQ_API_KEY=

DATABASE_URL=postgresql+asyncpg://buddy:buddy@localhost:5432/buddy

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=buddy

POSTGRES_USER=buddy
POSTGRES_PASSWORD=buddy
POSTGRES_DB=buddy

# Gmail account used to SEND task-reminder emails (needs a Gmail App
# Password, not your regular password: https://myaccount.google.com/apppasswords).
# Recipient address is set per-user from the Profile page, not here.
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=

# Cloudinary — used to store uploaded images (profile pictures for now).
# Get these from your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 — used specifically to store PDF resumes (S3-compatible).
# Create a bucket + API token at https://dash.cloudflare.com/ (R2 section),
# and enable the bucket's public R2.dev URL (or bind a custom domain) so
# R2_PUBLIC_URL_BASE resolves. No trailing slash on the URL base.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL_BASE=
